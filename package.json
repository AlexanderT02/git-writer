{
  "name": "git-worker",
  "version": "0.2.7",
  "description": "CLI to generate conventional commit messages and pull request descriptions from your Git changes using LLMs.",
  "bin": {
    "git-worker": "dist/index.js",
    "git-writer": "dist/index.js",
    "gw": "dist/index.js"
  },
  "type": "module",
  "dependencies": {
    "@inquirer/core": "^11.1.9",
    "@inquirer/prompts": "^8.4.2",
    "chalk": "^5.3.0",
    "clipboardy": "^5.3.1",
    "commander": "^14.0.3",
    "marked": "^15.0.12",
    "marked-terminal": "^7.3.0",
    "openai": "^4.0.0",
    "ora": "^8.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@types/marked": "^5.0.2",
    "@types/node": "^25.6.0",
    "eslint": "^9.39.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.2",
    "vitest": "^3.2.4"
  },
  "scripts": {
    "build": "tsc",
    "clean": "node -e \"fs.rmSync('dist',{recursive:true,force:true})\"",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "check": "npm run lint && npm run build",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepack": "npm run clean && npm run check && npm test",
    "release:patch": "npm version patch && git push --follow-tags",
    "release:minor": "npm version minor && git push --follow-tags",
    "release:major": "npm version major && git push --follow-tags"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ]
}